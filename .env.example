# ==============================================================================
# Toolchain Adapter v8 - Windows 环境变量配置
# 所有路径均使用 Windows 格式，Node.js 的 path.join() 会自动处理分隔符
# ==============================================================================

# ─── 多后端配置 ───
LM_STUDIO_BASE_URL=http://localhost:1234
LM_STUDIO_TIMEOUT=120000

# 后端类型: lmstudio 或 llamacpp
BACKEND_TYPE=lmstudio
# llama.cpp 服务器 URL（仅 llamacpp 后端使用）
LLAMACPP_BASE_URL=http://localhost:8080
# llama.cpp 是否启用 prompt 缓存（默认开启）
LLAMACPP_CACHE_PROMPT=true
# llama.cpp reasoning 格式（留空则不设置，可选 deepseek 等）
LLAMACPP_REASONING_FORMAT=


# ─── 适配器服务配置 ───
ADAPTER_PORT=1818
ADAPTER_HOST=0.0.0.0


# ─── 模型配置 ───
# 留空则使用请求中的模型名
MODEL_OVERRIDE=Qwen3.5-9B
DEFAULT_MODEL=local-model


# ─── 记忆存储配置 ───
# 是否启用 SSD 永久记忆存储（防止项目失忆，默认开启）
MEMORY_STORE_ENABLED=true
# 记忆存储目录（留空则使用项目根目录）
# Windows 路径示例: D:\toolchain-adapter 或留空
MEMORY_STORE_DIR=

# ─── 上下文提炼配置 ───
# 是否启用上下文提炼（在压缩前提取关键事实保存到记忆，默认开启）
CONTEXT_REFINER_ENABLED=true
# 提炼触发阈值比例（占 contextCompressionThreshold 的百分比，默认0.8即80%）
CONTEXT_REFINER_THRESHOLD_RATIO=0.8
# 记忆清理最大年龄（毫秒），默认7天
MEMORY_CLEANUP_MAX_AGE=604800000

# ─── 工具调用参数 ───
TOOL_CALL_TEMPERATURE=0.2
TOOL_CALL_MAX_TOKENS=8192

# ─── 上下文压缩配置 ───
CONTEXT_COMPRESSION_THRESHOLD=36168
CONTEXT_MAX_TOOLS=30
CONTEXT_TOOL_DESC_MAX_LENGTH=8192

# ─── 循环检测配置 ───
LOOP_DETECTION_ENABLED=true
LOOP_DETECTION_WINDOW_SIZE=30
# 精确匹配阈值（相同工具名+相同参数，默认3次触发）
LOOP_DETECTION_THRESHOLD=15
# 工具名频率阈值（同一工具不管参数，默认5次触发）
LOOP_DETECTION_TOOL_ONLY_THRESHOLD=25
# 请求内容哈希连续重复阈值（同一哈希从末尾连续重复N次触发）
LOOP_DETECTION_CONTENT_REPEAT_THRESHOLD=20
# 窗口内哈希重复阈值（同一哈希在时间窗口内出现N次触发，不管是否连续）
# 解决 OpenClaw 交替式死循环：A,B,A,B... 永远不会"连续"10次相同
LOOP_DETECTION_WINDOW_HASH_THRESHOLD=30
# 窗口回看时间（秒），默认300秒（5分钟）
LOOP_DETECTION_WINDOW_LOOKBACK_SECONDS=300
# 响应内容重复检测阈值（同一响应内容哈希连续重复N次触发）
LOOP_DETECTION_RESPONSE_REPEAT_THRESHOLD=10

# ─── 模拟调用修复配置 ───
SIMULATED_CALL_FIXER_ENABLED=true

# ─── Few-Shot 注入配置 ───
FEW_SHOT_ENABLED=true
FEW_SHOT_MAX_EXAMPLES=2

# ─── JSON 修复配置 ───
JSON_REPAIR_ENABLED=true

# ─── 响应语言配置 ───
# 响应语言：设置模型回复使用的语言代码
# 常用值: zh-CN (简体中文), zh-TW (繁體中文), en (英文), ja (日文), ko (韩文)
# 设为空字符串则不注入语言指令
# 默认 zh-CN，解决中文提问英文回答的问题
RESPONSE_LANGUAGE=zh-CN
# 自定义语言指令（如果设置，将覆盖默认的语言指令文本）
RESPONSE_LANGUAGE_INSTRUCTION=zh-CN
# 是否对响应内容进行语言修正
RESPONSE_LANGUAGE_FIX_ENABLED=true

# ─── 日志配置 ───
DEBUG_LOGGING=true
DIAGNOSTIC_LOGGING=true
DIAGNOSTIC_LOG_TO_FILE=true
EXCEPTION_LOG_TO_FILE=true
LOG_LEVEL=info

# ─── 流式响应配置 ───
STREAM_BUFFER_MS=50

# ─── 安全配置 ───
MAX_REQUEST_SIZE=10mb


